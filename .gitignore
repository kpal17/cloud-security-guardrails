@'
# Terraform local cache
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*

# Terraform plans
**/tfplan
**/tfplan.json
*.tfplan
*.tfplan.json

# Terraform variable files may contain secrets
*.tfvars
*.tfvars.json
!*.tfvars.example

# Crash logs
crash.log
crash.*.log
'@ | Set-Content ..\..\.gitignore